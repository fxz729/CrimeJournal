# ===== CrimeJournal 环境变量配置示例 =====
# 复制此文件为 backend/.env 并填入实际值
# 重要：不要将 .env 文件提交到 GitHub！

# ==================== 应用配置 ====================
APP_NAME=CrimeJournal
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True

# ==================== AI 服务配置 ====================
# MiniMax AI (统一 AI 服务 - 用于摘要、实体提取、关键词)
# 获取地址: https://platform.minimax.chat/
# 模型: MiniMax-Text-02 (M2.7 最新模型)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-02

# ==================== 法律数据配置 ====================
# CourtListener (免费法律案例数据)
# 获取地址: https://www.courtlistener.com/api/token/
COURTLISTENER_API_TOKEN=your_courtlistener_token_here

# ==================== 数据库配置 ====================
# 开发环境: SQLite (无需额外配置)
DATABASE_URL=sqlite:///./crimejournal.db

# 生产环境: Supabase PostgreSQL (500MB 免费)
# DATABASE_URL=postgresql://user:password@host:5432/crimejournal

# ==================== JWT 配置 ====================
# JWT 密钥 (请使用随机字符串)
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate_a_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== 向量模型配置 (本地免费) ====================
# Sentence-Transformers 模型 (无需 API key)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ==================== Redis 配置 (可选) ====================
# 生产环境可选: Upstash Redis (免费 3000 命令/天)
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 已废弃配置 (已迁移到 MiniMax) ====================
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# CLAUDE_API_KEY=your_claude_api_key_here
