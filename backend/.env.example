# ===== MiniMax配置（统一AI服务）=====
# 获取地址: https://platform.minimaxi.com/
# 模型: MiniMax-Text-02 (M2.7最新模型)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-02

# ===== CourtListener配置（法律数据）=====
# 获取地址: https://www.courtlistener.com/api/token/
COURTLISTENER_API_TOKEN=your_courtlistener_token_here

# ===== 数据库配置 =====
# 本地开发：SQLite（无需额外配置）
DATABASE_URL=sqlite:///./crimejournal.db
# 生产环境：Supabase PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/crimejournal

# ===== Redis配置 =====
REDIS_URL=redis://localhost:6379

# ===== JWT配置 =====
# 生成随机密钥: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate_a_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===== 向量模型配置（本地免费）=====
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===== 应用配置 =====
APP_NAME=CrimeJournal
APP_VERSION=1.0.0
DEBUG=True

# ===== 已废弃配置（保留兼容）=====
# DEEPSEEK_API_KEY=
# CLAUDE_API_KEY=
