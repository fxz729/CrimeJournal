# ===== MiniMax配置（核心AI服务）=====
# 获取地址: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-01

# ===== DeepSeek配置（辅助AI服务）=====
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ===== CourtListener配置（法律数据）=====
# 获取地址: https://www.courtlistener.com/api/token/
COURTLISTENER_API_TOKEN=your_courtlistener_token_here

# ===== 数据库配置 =====
# 本地开发：SQLite
DATABASE_URL=sqlite:///./crimejournal.db
# 生产环境：Supabase PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/crimejournal

# ===== Redis配置 =====
REDIS_URL=redis://localhost:6379

# ===== JWT配置 =====
# 生成随机密钥: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate_a_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===== 向量模型配置 =====
# 使用本地免费模型（sentence-transformers）
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ===== 应用配置 =====
APP_NAME=CrimeJournal
APP_VERSION=1.0.0
DEBUG=True

# ===== 兼容旧配置（已废弃）=====
# CLAUDE_API_KEY=
# CLAUDE_BASE_URL=
