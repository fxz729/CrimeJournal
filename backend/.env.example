# Claude Configuration
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_BASE_URL=

# DeepSeek Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# CourtListener Configuration
COURTLISTENER_API_TOKEN=your_courtlistener_token_here

# Database Configuration
# Use SQLite for local development
DATABASE_URL=sqlite:///./crimejournal.db
# Production: Use Supabase PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/crimejournal

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET_KEY=generate_a_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Embedding Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Application Settings
APP_NAME=CrimeJournal
APP_VERSION=1.0.0
DEBUG=True
