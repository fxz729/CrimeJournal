{
  "framework": "vite",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "devCommand": "cd frontend && npm run dev",
  "regions": ["hnd1"],
  "env": {
    "VITE_API_BASE_URL": {
      "description": "Backend API base URL - set to Render backend URL in production",
      "value": "https://crimejournal-api.onrender.com"
    },
    "VITE_APP_NAME": {
      "value": "CrimeJournal"
    }
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
