# CrimeJournal 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
APP_NAME=CrimeJournal
APP_VERSION=1.0.0
APP_ENV=development

# ==================== 数据库配置 ====================
# 开发环境 (SQLite)
DATABASE_URL=sqlite:///./data/crimejournal.db

# 生产环境 (PostgreSQL) - 取消注释并填写
# DATABASE_URL=postgresql://username:password@localhost:5432/crimejournal

# ==================== API 配置 ====================
# API 密钥
API_KEY=your-api-key-here

# ==================== AI 服务配置 ====================
# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ==================== 前端配置 ====================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================== 安全配置 ====================
# JWT 密钥 (请使用随机字符串)
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==================== CORS 配置 ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
